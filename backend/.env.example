# Saudi Market AI - Backend Environment Configuration

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/saudi_market_ai

# AI Model API Keys
# Google Gemini 1.5 Pro - for RAG document analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude 3.5 Sonnet - for logic/coding/financial calculations
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI - for text embeddings (text-embedding-3-large)
OPENAI_API_KEY=your_openai_api_key_here

# Search APIs
# Tavily Search API - for deep web competitor research
TAVILY_API_KEY=your_tavily_api_key_here

# Google Places API - for local competitor data
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Vector Database
QDRANT_URL=http://localhost:6333

# Security
JWT_SECRET=your_jwt_secret_key_change_in_production

# Environment
ENVIRONMENT=development
