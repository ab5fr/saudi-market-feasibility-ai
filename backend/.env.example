# Saudi Market AI - Backend Environment Configuration

# AI Model API Keys
# Google Gemini - for generation and embeddings
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override Gemini models
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Search APIs
# Tavily Search API - for deep web competitor research
TAVILY_API_KEY=your_tavily_api_key_here

# Google Places API - for local competitor data
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Vector Database
QDRANT_URL=http://localhost:6333

# Documents (optional overrides)
# DOCUMENTS_PATH=../documents
# DOCUMENTS_WATCH_INTERVAL_SECS=5

# Environment
ENVIRONMENT=development
